<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Activity Form View Extension -->
        <record id="view_mail_activity_form_real_estate" model="ir.ui.view">
            <field name="name">mail.activity.form.real.estate</field>
            <field name="model">mail.activity</field>
            <field name="inherit_id" ref="mail.mail_activity_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_deadline']" position="after">
                    <separator string="Location Information"/>
                    <group>
                        <group>
                            <field name="agent_latitude"/>
                            <field name="agent_longitude"/>
                        </group>
                        <group>
                            <field name="completion_latitude"/>
                            <field name="completion_longitude"/>
                        </group>
                    </group>
                    <group>
                        <field name="property_related"/>
                        <field name="project_id"/>
                        <field name="unit_id"/>
                    </group>
                </xpath>
                <xpath expr="//field[@name='date_deadline']" position="after">
                    <button name="action_view_location" type="object" string="View Location" class="btn-secondary"/>
                    <button name="action_view_completion_location" type="object" string="View Completion Location" class="btn-secondary"/>
                </xpath>
            </field>
        </record>

        <!-- Activity Tree View Extension -->
        <record id="view_mail_activity_tree_real_estate" model="ir.ui.view">
            <field name="name">mail.activity.tree.real.estate</field>
            <field name="model">mail.activity</field>
            <field name="inherit_id" ref="mail.mail_activity_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_deadline']" position="after">
                    <field name="property_related"/>
                    <field name="project_id" optional="hide"/>
                    <field name="unit_id" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
