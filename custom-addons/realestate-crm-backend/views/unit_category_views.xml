<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_real_estate_unit_category_tree" model="ir.ui.view">
            <field name="name">real.estate.unit.category.tree</field>
            <field name="model">real.estate.unit.category</field>
            <field name="arch" type="xml">
                <list string="Unit Categories">
                    <field name="complete_name"/>
                    <field name="parent_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_real_estate_unit_category_form" model="ir.ui.view">
            <field name="name">real.estate.unit.category.form</field>
            <field name="model">real.estate.unit.category</field>
            <field name="arch" type="xml">
                <form string="Unit Category">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_real_estate_unit_category_search" model="ir.ui.view">
            <field name="name">real.estate.unit.category.search</field>
            <field name="model">real.estate.unit.category</field>
            <field name="arch" type="xml">
                <search string="Unit Categories">
                    <field name="name"/>
                    <field name="parent_id"/>
                    <filter string="Main Types" name="main_types" domain="[('parent_id', '=', False)]"/>
                    <filter string="Sub Types" name="sub_types" domain="[('parent_id', '!=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Parent Category" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_real_estate_unit_category" model="ir.actions.act_window">
            <field name="name">Unit Types</field>
            <field name="res_model">real.estate.unit.category</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_real_estate_unit_category_search"/>
            <field name="context">{'search_default_main_types': 1}</field>
        </record>

    </data>
</odoo>
