<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_real_estate_installments" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.real.estate.installments</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Real Estate CRM" string="Real Estate CRM" name="real_estate_crm_installments">
                        <block title="Installments &amp; invoicing" name="real_estate_installment_settings">
                            <setting string="Automated installment invoices"
                                     help="Creates one draft customer invoice per installment line when the due date is within the selected horizon (0 = disabled). Full revenue recognition / deferred revenue should still follow your accountant’s chart (use Accounting › Configuration).">
                                <field name="installment_invoice_days_before"/>
                            </setting>
                            <setting string="Overdue chatter reminder"
                                     help="Posts a single reminder on the sales opportunity when an installment stays unpaid after this many days from due date (0 = disabled).">
                                <field name="installment_late_alert_after_days"/>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
