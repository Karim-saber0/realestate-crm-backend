<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- LOI Tree View -->
        <record id="view_real_estate_loi_tree" model="ir.ui.view">
            <field name="name">real.estate.loi.tree</field>
            <field name="model">real.estate.loi</field>
            <field name="arch" type="xml">
                <list string="Letters of Intent">
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="unit_id"/>
                    <field name="loi_date"/>
                    <field name="expiry_date"/>
                    <field name="unit_price"/>
                    <field name="reservation_amount"/>
                    <field name="status"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- LOI Form View -->
        <record id="view_real_estate_loi_form" model="ir.ui.view">
            <field name="name">real.estate.loi.form</field>
            <field name="model">real.estate.loi</field>
            <field name="arch" type="xml">
                <form string="Letter of Intent">
                    <header>
                        <button name="action_send_loi" type="object" string="Send LOI" class="btn-primary"/>
                        <button name="action_accept" type="object" string="Accept" class="btn-success"/>
                        <button name="action_reject" type="object" string="Reject" class="btn-danger"/>
                        <button name="action_convert_to_contract" type="object" string="Convert to Contract" class="btn-primary"/>
                        <button name="action_print_loi" type="object" string="Print LOI" class="btn-secondary"/>
                        <button name="action_view_unit_location" type="object" string="View Unit Location" class="btn-info"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,sent,accepted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="opportunity_id"/>
                                <field name="customer_id"/>
                                <field name="unit_id"/>
                                <field name="loi_date"/>
                                <field name="validity_days"/>
                                <field name="expiry_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="project_id" readonly="1"/>
                                <field name="sector_id" readonly="1"/>
                                <field name="building_id" readonly="1"/>
                                <field name="unit_type" readonly="1"/>
                                <field name="unit_area_sqft" readonly="1"/>
                                <field name="unit_price" readonly="1"/>
                                <field name="currency_id" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="reservation_amount"/>
                                <field name="unit_latitude" readonly="1"/>
                                <field name="unit_longitude" readonly="1"/>
                            </group>
                            <group>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="payment_terms" nolabel="1"/>
                        </group>
                        <group>
                            <field name="special_conditions" nolabel="1"/>
                        </group>
                        <group>
                            <field name="notes" nolabel="1"/>
                        </group>
                        <notebook>
                            <page string="Attachments">
                                <field name="attachment_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="mimetype"/>
                                        <field name="file_size"/>
                                        <field name="create_date"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- LOI Search View -->
        <record id="view_real_estate_loi_search" model="ir.ui.view">
            <field name="name">real.estate.loi.search</field>
            <field name="model">real.estate.loi</field>
            <field name="arch" type="xml">
                <search string="Search LOIs">
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="unit_id"/>
                    <field name="project_id"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Sent" name="sent" domain="[('status', '=', 'sent')]"/>
                    <filter string="Accepted" name="accepted" domain="[('status', '=', 'accepted')]"/>
                    <filter string="Rejected" name="rejected" domain="[('status', '=', 'rejected')]"/>
                    <filter string="Expired" name="expired" domain="[('status', '=', 'expired')]"/>
                    <separator/>
                    <filter string="Expiring Soon" name="expiring_soon" domain="[('expiry_date', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}"/>
                        <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                        <filter string="LOI Date" name="group_date" context="{'group_by': 'loi_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- LOI Action -->
        <record id="action_real_estate_loi" model="ir.actions.act_window">
            <field name="name">Letters of Intent</field>
            <field name="res_model">real.estate.loi</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_real_estate_loi_search"/>
            <field name="context">{'search_default_active': 1}</field>
        </record>

    </data>
</odoo>
