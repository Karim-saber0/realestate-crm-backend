<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_installment_auto_invoice" model="ir.cron">
            <field name="name">Real Estate: Draft invoices for upcoming installments</field>
            <field name="model_id" ref="model_real_estate_installment_line"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_invoice_upcoming_installments()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

        <record id="ir_cron_installment_overdue_reminder" model="ir.cron">
            <field name="name">Real Estate: Overdue installment chatter reminders</field>
            <field name="model_id" ref="model_real_estate_installment_line"/>
            <field name="state">code</field>
            <field name="code">model.cron_overdue_installment_chatter_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
