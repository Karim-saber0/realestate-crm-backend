<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Sequences -->
        <record id="seq_real_estate_loi" model="ir.sequence">
            <field name="name">Real Estate LOI</field>
            <field name="code">real.estate.loi</field>
            <field name="prefix">LOI</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Activity Types -->
        <record id="mail_activity_type_property_viewing" model="mail.activity.type">
            <field name="name">Property Viewing</field>
            <field name="category">default</field>
            <field name="summary">Property Viewing</field>
        </record>

        <record id="mail_activity_type_site_visit" model="mail.activity.type">
            <field name="name">Site Visit</field>
            <field name="category">default</field>
            <field name="summary">Site Visit</field>
        </record>

        <record id="mail_activity_type_customer_meeting" model="mail.activity.type">
            <field name="name">Customer Meeting</field>
            <field name="category">meeting</field>
            <field name="summary">Customer Meeting</field>
        </record>

        <record id="mail_activity_type_follow_up_call" model="mail.activity.type">
            <field name="name">Follow-up Call</field>
            <field name="category">phonecall</field>
            <field name="summary">Follow-up Call</field>
        </record>

        <record id="mail_activity_type_document_collection" model="mail.activity.type">
            <field name="name">Document Collection</field>
            <field name="category">default</field>
            <field name="summary">Document Collection</field>
        </record>

        <record id="mail_activity_type_contract_discussion" model="mail.activity.type">
            <field name="name">Contract Discussion</field>
            <field name="category">meeting</field>
            <field name="summary">Contract Discussion</field>
        </record>

        <record id="mail_activity_type_payment_discussion" model="mail.activity.type">
            <field name="name">Payment Discussion</field>
            <field name="category">meeting</field>
            <field name="summary">Payment Discussion</field>
        </record>

        <record id="ir_cron_real_estate_archive_installment_systems" model="ir.cron">
            <field name="name">Real Estate: Deactivate expired installment systems</field>
            <field name="model_id" ref="model_real_estate_installment_system"/>
            <field name="state">code</field>
            <field name="code">model._cron_archive_expired_systems()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
